# 40db-frontend — variables de entorno
#
# Copia este archivo a `.env.local` (gitignoreado por Vite) y completa los valores.
# Las claves que empiezan con `VITE_` son expuestas al bundle del cliente (ver
# https://vitejs.dev/guide/env-and-mode.html). NO pongas secretos server-side acá.

# Backend FastAPI deployado en Render.
# Producción: https://four0db-backend.onrender.com
# Local: http://localhost:8000 (o el puerto que use uvicorn)
VITE_API_BASE_URL=https://four0db-backend.onrender.com

# Supabase Auth — el front habla DIRECTO con Supabase para signup/login/refresh.
# La anon key es pública por diseño: solo permite operaciones de auth, no
# acceso a tablas (RLS habilitada sin políticas; ver auth.md §9 del back).
VITE_SUPABASE_URL=https://<tu-proyecto>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key-de-supabase>

# Habilita el área /admin-dashboard/* (UI-only, mocks).
# El backend MVP no expone los endpoints de admin todavía
# (ver docs/integracion-backend/02-endpoints-faltantes-back.md §1, §2, §3, §6).
# Dejar en `false` en producción y `true` para demos/dev.
VITE_ENABLE_ADMIN_DEMO=true
